apiVersion: v1
kind: Secret
metadata:
  name: db-credentials
  namespace: batch-jobs
type: Opaque
stringData:
  # Copy this file to secret.yaml and replace the placeholder.
  # secret.yaml is gitignored — never commit the real password.
  # Jenkins CD creates this Secret automatically from the
  # 'db-password' credential, so this file is only for manual
  # `kubectl apply` workflows outside the Jenkins pipeline.
  password: REPLACE_ME
